# ─────────────────────────────────────────────────────────────────────────────
# HR Policy AI Assistant — Single root .env
# Copy to .env and fill in all values before running docker-compose up
#
# Used by:
#   - Docker Compose          (reads automatically from root)
#   - NestJS backend          (env_file: ./.env in docker-compose)
#   - Vite frontend dev       (envDir: '..' in vite.config.ts)
#   - Frontend Docker build   (VITE_API_URL passed as build arg)
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME="HR Policy AI Assistant"
APP_DESCRIPTION="AI-powered HR policy assistant with RAG"

# ── Ports ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80
POSTGRES_PORT=5454     # host port for DB tools (DBeaver, psql, etc.)

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=change-me-in-production
DB_DATABASE=hr_assistant
DB_LOGGING=false
DB_SYNC=false

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_RESET_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Chroma ───────────────────────────────────────────────────────────────────
CHROMA_URL=http://chroma:8000        # use http://localhost:8000 for local dev
CHROMA_COLLECTION=hr_policies
RAG_SCORE_THRESHOLD=0.6

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOADS_DIR=uploads

# ── LangSmith (optional — set LANGSMITH_TRACING=true to enable) ───────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=hr-policy-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Frontend (VITE_* vars — baked into bundle at build time) ──────────────────
# Must be the public URL browsers use to reach the API
VITE_API_URL=http://localhost/api/v1
