{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(npm run test:e2e *)",
      "Bash(npm run test:cov)",
      "Bash(npm run build)",
      "Bash(npm run start:dev)",
      "Bash(npm run migration:*)",
      "Bash(npx jest *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(docker-compose ps)",
      "Bash(docker-compose logs *)",
      "Bash(docker-compose up -d)",
      "Bash(docker-compose down)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker-compose down -v)",
      "Bash(npm run migration:revert)",
      "Bash(DROP TABLE *)",
      "Bash(DELETE FROM *)",
      "Write(src/modules/chat/chat.service.ts)",
      "Write(src/modules/rag/retriever.service.ts)",
      "Write(src/modules/guardrails/**)"
    ],
    "guardrails_reminders": [
      "Always call InputGuard.validate() before any LLM or Qdrant call",
      "Always filter Qdrant search by tenantId from JWT — never from user input",
      "Always wrap context in <context>...</context> XML delimiters",
      "Always run ResponseFilter.scrubOutput() before persisting to DB",
      "Never return raw error messages, stack traces, or Qdrant IDs to clients",
      "Never interpolate dto.query directly into a prompt string",
      "Always handle the zero-docs retrieval case before calling the LLM"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const cmd=process.env.CLAUDE_TOOL_INPUT; if(/LANGCHAIN_API_KEY|OPENAI_API_KEY|ANTHROPIC_API_KEY|JWT_SECRET/.test(cmd)){process.exit(1);}\" || echo 'safe'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint --silent 2>&1 | tail -5 || true"
          }
        ]
      }
    ]
  },
  "env": {
    "LANGCHAIN_TRACING_V2": "true",
    "NODE_ENV": "development"
  }
}
