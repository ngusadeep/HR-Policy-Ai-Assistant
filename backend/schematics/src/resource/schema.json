{
  "$schema": "http://json-schema.org/schema",
  "$id": "ResourceSchematic",
  "title": "Resource Options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Resource name in kebab-case (e.g. product, blog-post)",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "Resource name (kebab-case):"
    }
  },
  "required": ["name"]
}
